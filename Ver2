void handleRoot() {
  server.send(200, "text/html", htmlPage());
}

void handleSetOpen() {
  if (server.hasArg("time")) {
    int h, m, s;
    if (parseTimeString(server.arg("time"), h, m, s)) {
      openHour = h;
      openMinute = m;
      openSecond = s;
      updateLCD();
    }
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleSetClose() {
  if (server.hasArg("time")) {
    int h, m, s;
    if (parseTimeString(server.arg("time"), h, m, s)) {
      closeHour = h;
      closeMinute = m;
      closeSecond = s;
      updateLCD();
    }
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleSetRTC() {
  if (server.hasArg("time")) {
    int h, m, s;
    if (parseTimeString(server.arg("time"), h, m, s)) {
      setRTCFromValues(h, m, s);
      updateLCD();
    }
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleOpenNow() {
  setDoorOpen(true);
  updateLCD();
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleCloseNow() {
  setDoorOpen(false);
  updateLCD();
  server.sendHeader("Location", "/");
  server.send(303);
}

void setupWebAP() {
  WiFi.mode(WIFI_AP);
  WiFi.softAP(apSSID, apPassword);

  IPAddress IP = WiFi.softAPIP();

  server.on("/", handleRoot);
  server.on("/setOpen", handleSetOpen);
  server.on("/setClose", handleSetClose);
  server.on("/setRTC", handleSetRTC);
  server.on("/openNow", handleOpenNow);
  server.on("/closeNow", handleCloseNow);
  server.begin();

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("AP: ESP32_DOOR");
  lcd.setCursor(0, 1);
  lcd.print(IP.toString());
  delay(3000);
}

void setup() {
  Wire.begin(SDA_PIN, SCL_PIN);

  pinMode(buttonManual, INPUT_PULLUP);
  pinMode(buttonSet, INPUT_PULLUP);
  pinMode(encCLKPin, INPUT_PULLUP);
  pinMode(encDTPin, INPUT_PULLUP);

  pinMode(ledRed, OUTPUT);
  pinMode(ledGreen, OUTPUT);

  lockServo.setPeriodHertz(50);
  lockServo.attach(servoPin, 500, 2400);

  if (!rtc.begin()) {
    while (1);
  }

  lcd.begin(16, 2);
  lcd.backlight();
  lcd.clear();

  DateTime now = rtc.now();

  closeHour = now.hour();
  closeMinute = now.minute();
  closeSecond = (now.second() + 20) % 60;

  openHour = now.hour();
  openMinute = now.minute();
  openSecond = (now.second() + 40) % 60;

  rtcSetHour = now.hour();
  rtcSetMinute = now.minute();
  rtcSetSecond = now.second();

  setDoorOpen(true);

  int MSB = digitalRead(encCLKPin);
  int LSB = digitalRead(encDTPin);
  lastEncoded = (MSB << 1) | LSB;

  setupWebAP();
  updateLCD();
}

void loop() {
  DateTime now = rtc.now();

  server.handleClient();

  if (isButtonPressed(btnManual) && settingMode == SET_NONE) {
    setDoorOpen(!doorOpen);
    updateTopLine();
  }

  handleSetHold();
  handleSetShortPress();
  handleEncoderRotation();
  handleSettingTimeout();
  handleAutoOpenClose();

  if (settingMode != SET_NONE && millis() - lastBlinkMillis >= 300) {
    lastBlinkMillis = millis();
    blinkState = !blinkState;
    updateBottomLine();
  }

  if (now.second() != lastShownSecond && settingMode == SET_NONE) {
    lastShownSecond = now.second();
    updateTopLine();
  }

  if (settingMode == SET_NONE && millis() - lastBottomToggle >= 3000) {
    lastBottomToggle = millis();
    showNextClose = !showNextClose;
    updateBottomLine();
  }

  delay(2);
}
